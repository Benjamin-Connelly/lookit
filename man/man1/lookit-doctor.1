.TH "LOOKIT" "1" "Mar 2026" "lookit v0.4.0-dev" ""

.SH NAME
lookit-doctor - Check environment and diagnose issues


.SH SYNOPSIS
\fBlookit doctor [flags]\fP


.SH DESCRIPTION
Run diagnostic checks on your environment and report results.

.PP
Checks: Go version, Git version, git repo detection, .gitignore presence,
terminal size and capabilities, config file loading, markdown file count,
large file warnings, and wkhtmltopdf availability (for PDF export).


.SH OPTIONS
\fB-h\fP, \fB--help\fP[=false]
	help for doctor


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB-c\fP, \fB--config\fP=""
	config file path

.PP
\fB--debug\fP[=false]
	enable verbose logging

.PP
\fB--no-color\fP[=false]
	disable colors (ascii theme)

.PP
\fB--theme\fP=""
	color theme (light|dark|auto|ascii)


.SH EXAMPLE
.EX
  lookit doctor
.EE


.SH SEE ALSO
\fBlookit(1)\fP


