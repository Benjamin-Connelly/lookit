.SH NAME
lookit-completion - Set up shell completions for lookit


.SH SYNOPSIS
\fBlookit completion [bash|zsh|fish|powershell] [flags]\fP


.SH DESCRIPTION
Set up shell completions so you get tab-completion for commands, flags, and file paths.

.PP
Run without arguments to auto-detect your shell and install interactively.
Run with a shell name to output the raw completion script (for custom setups).

.PP
Examples:
  lookit completion              # Interactive setup (recommended)
  lookit completion bash         # Print raw bash completion script
  lookit completion --install    # Auto-detect shell and install without prompts


.SH OPTIONS
\fB-h\fP, \fB--help\fP[=false]
	help for completion

.PP
\fB--install\fP[=false]
	auto-detect shell and install without prompts


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB-c\fP, \fB--config\fP=""
	config file path

.PP
\fB--debug\fP[=false]
	enable verbose logging

.PP
\fB--no-color\fP[=false]
	disable colors (ascii theme)

.PP
\fB--theme\fP=""
	color theme (light|dark|auto)


.SH SEE ALSO
\fBlookit(1)\fP


