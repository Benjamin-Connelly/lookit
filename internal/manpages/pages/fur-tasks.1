.SH NAME
fur-tasks - Extract and list TODO items from markdown files


.SH SYNOPSIS
\fBfur tasks [path] [flags]\fP


.SH DESCRIPTION
Extract TODO/FIXME checkbox items from markdown files and display them
in a formatted table. Recognizes priority markers (!high, !medium, !low),
tags (#tag), and due dates (@due(YYYY-MM-DD)).

.PP
Tasks are extracted from markdown checkbox syntax:
  - [ ] Unchecked task
  - [x] Completed task
  - [ ] !high Urgent task with priority
  - [ ] Fix bug #backend @due(2025-01-15)


.SH OPTIONS
\fB-h\fP, \fB--help\fP[=false]
	help for tasks

.PP
\fB--json\fP[=false]
	output as JSON array

.PP
\fB--pending\fP[=false]
	show only unchecked tasks


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB-c\fP, \fB--config\fP=""
	config file path

.PP
\fB--debug\fP[=false]
	enable verbose logging

.PP
\fB--no-color\fP[=false]
	disable colors (ascii theme)

.PP
\fB--theme\fP=""
	color theme (light|dark|auto|ascii)


.SH EXAMPLE
.EX
  fur tasks
  fur tasks ~/docs
  fur tasks --pending
  fur tasks --json | jq '.[] | select(.priority == "high")'
.EE


.SH SEE ALSO
\fBfur(1)\fP


