.SH NAME
fur-completion - Set up shell completions for fur


.SH SYNOPSIS
\fBfur completion [bash|zsh|fish|powershell] [flags]\fP


.SH DESCRIPTION
Set up shell completions so you get tab-completion for commands, flags, and file paths.

.PP
Run without arguments to auto-detect your shell and install interactively.
Run with a shell name to output the raw completion script (for custom setups).

.PP
Examples:
  fur completion              # Interactive setup (recommended)
  fur completion bash         # Print raw bash completion script
  fur completion --install    # Auto-detect shell and install without prompts


.SH OPTIONS
\fB-h\fP, \fB--help\fP[=false]
	help for completion

.PP
\fB--install\fP[=false]
	auto-detect shell and install without prompts


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB-c\fP, \fB--config\fP=""
	config file path

.PP
\fB--debug\fP[=false]
	enable verbose logging

.PP
\fB--no-color\fP[=false]
	disable colors (ascii theme)

.PP
\fB--theme\fP=""
	color theme (light|dark|auto|ascii)


